    "Double tap to filter spend trends to this card. Tap again to clear and return to period P." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر نقرًا مزدوجًا لتصفية اتجاهات الإنفاق لهذه البطاقة. اضغط مرة أخرى للمسح والعودة إلى الفترة P."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie zweimal, um die Ausgabentrends für diese Karte zu filtern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca dos veces para filtrar tendencias de gasto en esta tarjeta. Toca de nuevo para limpiar y volver al período P."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez deux fois pour filtrer les tendances de dépenses sur cette carte. Touchez de nouveau pour effacer et revenir à la période P."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque duas vezes para filtrar tendências de gastos neste cartão. Toque novamente para limpar e retornar ao período P."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "双击可过滤此卡的支出趋势。再次点击可清除并返回 P 时段。"
          }
        }
      }
    },
