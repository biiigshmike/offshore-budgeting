    "Deleting these removes them from their cards too." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي حذفها إلى إزالتها من بطاقاتهم أيضًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie diese löschen, werden sie auch von ihren Karten entfernt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al eliminarlos, también se quitarán de sus tarjetas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les supprimer les retirera aussi de leurs cartes."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excluí-los também os remove de seus cartões."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除这些也会将它们从卡片中删除。"
          }
        }
      }
    },
    "Deleting these will remove the expenses from their cards too." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي حذفها إلى إزالة النفقات من بطاقاتهم أيضًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie diese löschen, werden auch die Ausgaben von ihren Karten entfernt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al eliminarlos tambien se quitaran esos gastos de sus cuentas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les supprimer retirera aussi les dépenses de leurs cartes."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excluí-los também removerá as despesas de seus cartões."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除这些也会从他们的卡中删除费用。"
          }
        }
      }
    },
    "Deleting this split charge will remove the split and restore the original gross expense amount." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي حذف هذه الرسوم المقسمة إلى إزالة التقسيم واستعادة مبلغ النفقات الإجمالي الأصلي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch das Löschen dieser aufgeteilten Gebühr wird die Aufteilung entfernt und der ursprüngliche Bruttoausgabenbetrag wiederhergestellt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eliminar este cargo dividido quitará la división y restaurará el monto bruto original del gasto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprimer cette dépense fractionnée retirera le fractionnement et rétablira le montant brut d’origine."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A exclusão desta cobrança dividida removerá a divisão e restaurará o valor da despesa bruta original."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除此拆分费用将删除拆分并恢复原始总费用金额。"
          }
        }
      }
    },
    "Deleting this split charge will remove the split without changing the original expense amount." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي حذف هذا الرسم المقسم الى ازالة التقسيم من دون تغيير مبلغ المصروف الاصلي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn diese geteilte Buchung geloescht wird, wird die Aufteilung entfernt, ohne den urspruenglichen Ausgabenbetrag zu aendern."
