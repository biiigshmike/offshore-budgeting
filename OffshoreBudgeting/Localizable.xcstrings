            "state" : "translated",
            "value" : "على شاشة عندما أقوم بالنقر...، انقر فوق إنشاء اختصار جديد في قسم البدء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie im Bildschirm „Wenn ich auf … tippe“ im Abschnitt „Erste Schritte“ auf „Neue Verknüpfung erstellen“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On the When I Tap... screen, tap Create New Shortcut in the Get Started section."
          }
        },
        "es" : {
