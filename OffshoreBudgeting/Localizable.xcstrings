        }
      }
    },
    "To pass transaction amount and merchant details, tap the Amount field, choose Select Variable, then choose Shortcut Input." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لتمرير مبلغ المعاملة وتفاصيل التاجر، اضغط على حقل المبلغ، واختر تحديد متغير، ثم اختر إدخال الاختصار."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um den Transaktionsbetrag und die Händlerdetails zu übergeben, tippen Sie auf das Feld „Betrag“, wählen Sie „Variable auswählen“ und dann „Shortcut-Eingabe“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To pass transaction amount and merchant details, tap the Amount field, choose Select Variable, then choose Shortcut Input."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para pasar el importe de la transacción y los detalles del comercio, toca el campo Importe, elige Seleccionar variable y luego Entrada del atajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour transmettre le montant de la transaction et les détails du commerçant, touchez le champ Montant, choisissez Sélectionner une variable, puis Entrée du raccourci."
          }
        }
      }
    },
    "To use iCloud sync, sign in to iCloud in the Settings app, then return here and try again." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لاستخدام مزامنة iCloud، قم بتسجيل الدخول إلى iCloud في تطبيق الإعدادات، ثم قم بالعودة إلى هنا وحاول مرة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um die iCloud-Synchronisierung zu verwenden, melden Sie sich in der App „Einstellungen“ bei iCloud an, kehren Sie dann hierher zurück und versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar sincronizacion con iCloud, inicia sesion en iCloud en la app Ajustes y luego vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use iCloud sync, sign in to iCloud in the Réglages app, then return here and try again."
          }
        }
      }
    },
    "To use iCloud sync, sign in to iCloud in the Settings app, then try again." : {
