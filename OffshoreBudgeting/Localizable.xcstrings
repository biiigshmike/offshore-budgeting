    "Updated the Card creation form with a new Effects feature. Find the perfect effect to pair with your Card’s theme." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تحديث نموذج إنشاء البطاقة بميزة التأثيرات الجديدة. ابحث عن التأثير المثالي الذي يتناسب مع سمة بطاقتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Kartenerstellungsformular wurde mit einer neuen Effektfunktion aktualisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Updated the Card creation form with a new Effects feature. Find the perfect effect to pair with your Card’s theme."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se actualizó el formulario de creación de tarjetas con una nueva función de efectos. Encuentra el efecto perfecto para combinar con el tema de tu tarjeta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le formulaire de création de carte a été mis à jour avec une nouvelle fonction d’effets. Trouvez l’effet parfait à associer au thème de votre carte."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atualizado o formulário de criação de cartas com um novo recurso de efeitos. Encontre o efeito perfeito para combinar com o tema do seu cartão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用新的效果功能更新了卡片创建表单。找到与您的卡片主题搭配的完美效果。"
          }
        }
      }
    },
