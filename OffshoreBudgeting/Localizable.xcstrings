    "On Device stores data only on this device. iCloud syncs across devices signed into the same Apple ID." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقوم الخيار \"على الجهاز\" بتخزين البيانات على هذا الجهاز فقط. تتم مزامنة iCloud عبر الأجهزة المسجلة باستخدام نفس معرف Apple."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On Device speichert Daten nur auf diesem Gerät."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En este dispositivo guarda datos solo en este dispositivo. iCloud sincroniza entre dispositivos con el mismo Apple ID."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sur l’appareil stocke les données uniquement sur cet appareil. iCloud synchronise les appareils connectés avec le même identifiant Apple."
          }
        }
      }
    },
    "On the When I Tap... screen, tap Create New Shortcut in the Get Started section." : {
