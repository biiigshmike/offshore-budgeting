      }
    },
    "On this screen, scroll down and choose Wallet: When I Tap a Wallet Card or Pass." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في هذه الشاشة، قم بالتمرير لأسفل واختر Wallet: عندما أقوم بالنقر فوق بطاقة Wallet أو Pass."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scrollen Sie auf diesem Bildschirm nach unten und wählen Sie „Wallet: Wenn ich auf eine Wallet-Karte oder einen Wallet-Pass tippe“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On this screen, scroll down and choose Wallet: When I Tap a Wallet Card or Pass."
          }
        },
        "es" : {
          "stringUnit" : {
