    "I parsed your clipboard, but couldn't classify any import rows." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد قمت بتحليل الحافظة الخاصة بك، ولكن لم أتمكن من تصنيف أي صفوف استيراد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich habe Ihre Zwischenablage analysiert, konnte aber keine Importzeilen klassifizieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analicé tu portapapeles, pero no pude clasificar ninguna fila de importación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "J’ai analysé votre presse-papiers, mais je n’ai pas pu classer les lignes à importer."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
