    "Single-press categories to filter expenses; tap selected chips to clear one. Long-press to edit category limits." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فئات الضغط الواحد لتصفية النفقات؛ اضغط على الرقائق المحددة لمسح واحدة. اضغط لفترة طويلة لتعديل حدود الفئات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch einmaliges Drücken von Kategorien können Sie Ausgaben filtern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulsa una vez una categoria para filtrar gastos; toca una etiqueta seleccionada para quitarla. Mantener pulsado para editar limites de categoria."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez une fois les catégories pour filtrer les dépenses ; touchez les pastilles sélectionnées pour en effacer une. Maintenez pour modifier les limites de catégorie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Categorias de toque único para filtrar despesas; toque nos chips selecionados para limpar um. Mantenha pressionado para editar os limites da categoria."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "单按类别过滤费用；点击选定的筹码即可清除其中一个。长按可编辑类别限制。"
          }
        }
      }
    },
