    "Compare planned and actual income quickly to spot shortfalls early." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قارن بين الدخل المخطط والفعلي بسرعة لرصد النقص مبكرًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vergleichen Sie geplante und tatsächliche Einnahmen schnell, um Fehlbeträge frühzeitig zu erkennen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compare planned and actual income quickly to spot shortfalls early."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compara rápidamente los ingresos planificados y reales para detectar faltantes temprano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparez rapidement le revenu prévu et le revenu réel pour repérer tôt les manques."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compare rapidamente a receita planejada e a real para detectar deficiências antecipadamente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速比较计划收入和实际收入，及早发现不足。"
          }
        }
      }
    },
    "Complete fields, apply split or offset if needed, then verify totals after save." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أكمل الحقول، وقم بتطبيق التقسيم أو الإزاحة إذا لزم الأمر، ثم تحقق من الإجماليات بعد الحفظ."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füllen Sie die Felder aus, wenden Sie bei Bedarf eine Aufteilung oder einen Offset an und überprüfen Sie die Gesamtsummen nach dem Speichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Complete fields, apply split or offset if needed, then verify totals after save."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completa los campos, aplica división o compensación si hace falta y luego verifica los totales después de guardar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Complétez les champs, appliquez un fractionnement ou une compensation si nécessaire, puis vérifiez les totaux après l’enregistrement."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preencha os campos, aplique divisão ou compensação, se necessário, e verifique os totais após salvar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "填写字段，根据需要应用拆分或偏移，然后在保存后验证总计。"
          }
        }
      }
    },
    "Confirm amount and add a short note so settlement history stays clear." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتأكيد المبلغ وأضف ملاحظة قصيرة حتى يظل سجل التسوية واضحًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bestätigen Sie den Betrag und fügen Sie eine kurze Notiz hinzu, damit der Abrechnungsverlauf klar bleibt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirm amount and add a short note so settlement history stays clear."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirma el importe y agrega una nota corta para que el historial de liquidación se mantenga claro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmez le montant et ajoutez une courte note pour que l’historique des règlements reste clair."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirme o valor e adicione uma breve nota para que o histórico de liquidação permaneça claro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确认金额并添加简短注释，以便结算历史记录保持清晰。"
          }
        }
      }
    },
