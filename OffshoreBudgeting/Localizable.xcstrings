          }
        }
      }
    },
    "Add these screenshots to provide a visual walkthrough for new users.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add these screenshots to provide a visual walkthrough for new users."
          }
        },
        "es": {
