        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una tarjeta para esta automatización, selecciona una categoría para obtener los mejores resultados, establece Ejecutar inmediatamente y desactiva Notificar al ejecutar."
          }
        },
