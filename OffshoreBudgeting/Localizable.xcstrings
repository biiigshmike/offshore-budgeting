    "App-wide accessibility updates, including Dynamic Type support and improved contrast. The Home grid was simplified to ensure full compliance." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحديثات إمكانية الوصول على مستوى التطبيق، بما في ذلك دعم النوع الديناميكي والتباين المحسن. تم تبسيط الشبكة الرئيسية لضمان الامتثال الكامل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
