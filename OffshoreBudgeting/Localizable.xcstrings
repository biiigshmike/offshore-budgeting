      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على البطاقة لعرض الإنفاق حسب الفئة للبطاقة المحددة. اضغط عليه مرة أخرى لمسح اختيارك."
          }
        },
        "de" : {
          "stringUnit" : {
