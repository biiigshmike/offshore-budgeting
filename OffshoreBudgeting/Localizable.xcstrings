          }
        }
      }
    },
    "Swipe gestures are now available for use on the budgets list while the Budgets tab is active.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe gestures are now available for use on the budgets list while the Budgets tab is active."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los gestos de deslizamiento ahora están disponibles en la lista de presupuestos cuando la pestaña Presupuestos está activa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les gestes de balayage sont maintenant disponibles dans la liste des budgets lorsque l’onglet Budgets est actif."
          }
        }
      }
    },
    "Category Selection": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Category Selection"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selección de categorías"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélection de catégories"
          }
        }
      }
    },
    "When viewing the details for a selected budget or card, multiple categories can now be selected for filtering. Previously, only one category could be selected at a time.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When viewing the details for a selected budget or card, multiple categories can now be selected for filtering. Previously, only one category could be selected at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al ver los detalles de un presupuesto o una tarjeta seleccionados, ahora se pueden elegir varias categorías para filtrar. Antes, solo se podía seleccionar una categoría a la vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lors de l’affichage des détails d’un budget ou d’une carte sélectionnée, plusieurs catégories peuvent maintenant être choisies pour filtrer. Auparavant, une seule catégorie pouvait être sélectionnée à la fois."
          }
        }
      }
    },
    "The Quick Actions options for Add Income to Offshore, Add Expense to Offshore, and Tap to Pay have been removed.\n\nWhile the goal was to share Tap to Pay automations through Shortcuts, reliable setup proved difficult. The Help Guide now includes step-by-step instructions to configure these automations manually on the device you want to use with Tap to Pay.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Quick Actions options for Add Income to Offshore, Add Expense to Offshore, and Tap to Pay have been removed.\n\nWhile the goal was to share Tap to Pay automations through Shortcuts, reliable setup proved difficult. The Help Guide now includes step-by-step instructions to configure these automations manually on the device you want to use with Tap to Pay."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminaron las opciones de Acciones rápidas para Agregar ingreso a Offshore, Agregar gasto a Offshore y Tap to Pay.\n\nAunque el objetivo era compartir automatizaciones de Tap to Pay mediante Atajos, una configuración confiable resultó difícil. La Guía de ayuda ahora incluye instrucciones paso a paso para configurar estas automatizaciones manualmente en el dispositivo que quieras usar con Tap to Pay."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les options Actions rapides pour Ajouter un revenu à Offshore, Ajouter une dépense à Offshore et Tap to Pay ont été supprimées.\n\nMême si l’objectif était de partager les automatisations Tap to Pay via Raccourcis, une configuration fiable s’est avérée difficile. Le guide d’aide inclut maintenant des instructions pas à pas pour configurer ces automatisations manuellement sur l’appareil que vous souhaitez utiliser avec Tap to Pay."
          }
        }
      }
    },
    "Quality of Life Improvements": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quality of Life Improvements"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoras de calidad de vida"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorations du quotidien"
          }
        }
      }
    },
    "2.3.1 includes quality of life improvements.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2.3.1 includes quality of life improvements."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La versión 2.3.1 incluye mejoras de calidad de vida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La version 2.3.1 inclut des améliorations du quotidien."
          }
        }
      }
    },
    "Squashed Bugs": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Squashed Bugs"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Errores corregidos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugs corrigés"
          }
        }
      }
    },
    "Fixed a bug on Accounts where pressing the plus button did not render the Add Card or Add Reconcilation form.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fixed a bug on Accounts where pressing the plus button did not render the Add Card or Add Reconcilation form."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se corrigió un error en Cuentas por el que al pulsar el botón más no se mostraba el formulario para agregar una tarjeta o una conciliación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Correction d’un bug dans Comptes où le bouton plus n’affichait pas le formulaire Ajouter une carte ou Ajouter un rapprochement."
          }
        }
      }
    },
    "Enhancements to Savings Account": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enhancements to Savings Account"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoras en la Cuenta de ahorros"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorations du compte d’épargne"
          }
        }
      }
    },
    "The in-app, workspace-scoped Savings Account now supports adding negative manual entries to transfer any amount of the running balance 'out' of the savings account to reflect when funds are moved to your actual bank's savings account.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The in-app, workspace-scoped Savings Account now supports adding negative manual entries to transfer any amount of the running balance 'out' of the savings account to reflect when funds are moved to your actual bank's savings account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La Cuenta de ahorros integrada en la app y limitada al espacio de trabajo ahora permite agregar movimientos manuales negativos para sacar cualquier monto del saldo acumulado y reflejar cuando los fondos se mueven a la cuenta de ahorros real de tu banco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compte d’épargne intégré à l’app et propre à l’espace de travail permet maintenant d’ajouter des entrées manuelles négatives pour sortir n’importe quel montant du solde cumulé et refléter le moment où des fonds sont transférés vers le compte d’épargne réel de votre banque."
          }
        }
      }
    },
    "Splitting Transactions": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Splitting Transactions"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "División de transacciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fractionnement des transactions"
          }
        }
      }
    },
    "Splitting transactions now supports splitting by percentage using a slider. This makes it so that the split amount value can be calculated easily.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Splitting transactions now supports splitting by percentage using a slider. This makes it so that the split amount value can be calculated easily."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La división de transacciones ahora permite dividir por porcentaje usando un deslizador. Esto facilita calcular el valor del monto dividido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fractionnement des transactions permet maintenant de répartir par pourcentage à l’aide d’un curseur. Cela facilite le calcul du montant réparti."
          }
        }
      }
    },
    "Welcome Aboard, Marina!": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome Aboard, Marina!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Bienvenida a bordo, Marina!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenue à bord, Marina !"
          }
        }
      }
    },
    "Marina is Offshore’s new on-device financial assistant, available on the Home tab. She’s just getting her sea legs, so please be patient as she learns her way around. Marina runs entirely on your device and will improve with time. Try chatting with her to add income or expenses, explore savings goals, or gain quick insights into your finances.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Marina is Offshore’s new on-device financial assistant, available on the Home tab. She’s just getting her sea legs, so please be patient as she learns her way around. Marina runs entirely on your device and will improve with time. Try chatting with her to add income or expenses, explore savings goals, or gain quick insights into your finances."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marina es la nueva asistente financiera en el dispositivo de Offshore, disponible en la pestaña Panel. Apenas está encontrando su rumbo, así que ten paciencia mientras aprende a navegar. Marina funciona completamente en tu dispositivo y mejorará con el tiempo. Prueba chatear con ella para agregar ingresos o gastos, explorar metas de ahorro u obtener información rápida sobre tus finanzas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Marina est la nouvelle assistante financière sur l’appareil d’Offshore, disponible dans l’onglet Accueil. Elle prend encore ses marques, alors merci d’être patient pendant qu’elle apprend à s’y retrouver. Marina fonctionne entièrement sur votre appareil et s’améliorera avec le temps. Essayez de discuter avec elle pour ajouter des revenus ou des dépenses, explorer des objectifs d’épargne ou obtenir rapidement des informations sur vos finances."
          }
        }
      }
    },
    "Heading out to explore? Activate Excursion Mode to receive gentle reminders to log expenses when you’re near relevant points of interest. All processing happens on-device and can be turned on or off anytime.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Heading out to explore? Activate Excursion Mode to receive gentle reminders to log expenses when you’re near relevant points of interest. All processing happens on-device and can be turned on or off anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Vas a salir a explorar? Activa el Modo Excursión para recibir recordatorios suaves para registrar gastos cuando estés cerca de puntos de interés relevantes. Todo el procesamiento ocurre en el dispositivo y puede activarse o desactivarse en cualquier momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous partez explorer ? Activez le mode Excursion pour recevoir de petits rappels afin d’enregistrer vos dépenses lorsque vous êtes près de points d’intérêt pertinents. Tout le traitement se fait sur l’appareil et peut être activé ou désactivé à tout moment."
          }
        }
      }
    },
    "Reconciliations and Savings: Now on the Accounts Tab": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconciliations and Savings: Now on the Accounts Tab"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conciliaciones y ahorros: ahora en la pestaña Cuentas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapprochements et épargne : désormais dans l’onglet Comptes"
          }
        }
      }
    },
    "Accounts is now your place for Cards, Reconciliations, and a workspace-scoped Savings Account! You can now split expenses and track reconciliations. When adding or editing an expense, choose to split or offset it against a Reconciliation. View the running total and full expense history in Cards > Reconciliation. At the end of your budget periods, your Savings Account will keep a running total. This feature is designed to help offset future expenses with any surplus savings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accounts is now your place for Cards, Reconciliations, and a workspace-scoped Savings Account! You can now split expenses and track reconciliations. When adding or editing an expense, choose to split or offset it against a Reconciliation. View the running total and full expense history in Cards > Reconciliation. At the end of your budget periods, your Savings Account will keep a running total. This feature is designed to help offset future expenses with any surplus savings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuentas ahora es tu espacio para Tarjetas, Conciliaciones y una Cuenta de ahorros por espacio de trabajo. Ahora puedes dividir gastos y llevar el seguimiento de conciliaciones. Al agregar o editar un gasto, elige dividirlo o compensarlo contra una Conciliación. Consulta el total acumulado y el historial completo de gastos en Tarjetas > Conciliación. Al final de tus periodos de presupuesto, tu Cuenta de ahorros mantendrá un total acumulado. Esta función está diseñada para ayudar a compensar gastos futuros con cualquier ahorro sobrante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comptes regroupe désormais Cartes, Rapprochements et un Compte d’épargne propre à l’espace de travail. Vous pouvez maintenant fractionner les dépenses et suivre les rapprochements. Lors de l’ajout ou de la modification d’une dépense, choisissez de la fractionner ou de la compenser avec un Rapprochement. Consultez le total cumulé et l’historique complet des dépenses dans Cartes > Rapprochement. À la fin de vos périodes budgétaires, votre Compte d’épargne conservera un total cumulé. Cette fonction est conçue pour aider à compenser de futures dépenses avec l’épargne excédentaire."
          }
        }
      }
    },
    "Optional Quick Actions are now available through Shortcuts and Automations. You’ll see them during Onboarding and in Settings > Install Quick Actions.\n\nThese are completely optional and can help automate adding income from SMS or email notifications, as well as logging expenses from Apple Wallet taps. Offshore works perfectly without them.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional Quick Actions are now available through Shortcuts and Automations. You’ll see them during Onboarding and in Settings > Install Quick Actions.\n\nThese are completely optional and can help automate adding income from SMS or email notifications, as well as logging expenses from Apple Wallet taps. Offshore works perfectly without them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las Acciones rápidas opcionales ahora están disponibles mediante Atajos y Automatizaciones. Las verás durante la bienvenida y en Ajustes > Instalar Acciones rápidas.\n\nSon completamente opcionales y pueden ayudar a automatizar el agregado de ingresos desde SMS o notificaciones por correo, así como el registro de gastos desde toques en Apple Wallet. Offshore funciona perfectamente sin ellas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des Actions rapides facultatives sont maintenant disponibles via Raccourcis et Automatisations. Vous les verrez pendant la bienvenue et dans Réglages > Installer les Actions rapides.\n\nElles sont entièrement facultatives et peuvent aider à automatiser l’ajout de revenus depuis des SMS ou des notifications e-mail, ainsi que l’enregistrement des dépenses à partir des contacts Apple Wallet. Offshore fonctionne parfaitement sans elles."
          }
        }
      }
    },
    "Screen-Aware Keyboard Shortcuts": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen-Aware Keyboard Shortcuts"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atajos de teclado según la pantalla"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccourcis clavier adaptés à l’écran"
          }
        }
      }
    },
    "The iPad and Mac menu bar has been refined with screen-aware keyboard shortcuts. Shortcuts now appear only where relevant and are organized into the appropriate menu sections.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The iPad and Mac menu bar has been refined with screen-aware keyboard shortcuts. Shortcuts now appear only where relevant and are organized into the appropriate menu sections."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La barra de menús en iPad y Mac se ha refinado con atajos de teclado según la pantalla. Los atajos ahora aparecen solo donde son relevantes y están organizados en las secciones de menú adecuadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La barre de menus sur iPad et Mac a été affinée avec des raccourcis clavier adaptés à l’écran. Les raccourcis n’apparaissent maintenant que là où ils sont pertinents et sont organisés dans les sections de menu appropriées."
          }
        }
      }
    },
    "In Settings > General > Expense Display, it is now possible to hide future expenses from view, as well as excluding future expenses from being calculated. To toggle this temporarily, look for the eye button on Budget Details and Card Details.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In Settings > General > Expense Display, it is now possible to hide future expenses from view, as well as excluding future expenses from being calculated. To toggle this temporarily, look for the eye button on Budget Details and Card Details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En Ajustes > General > Visualización de gastos, ahora es posible ocultar los gastos futuros de la vista, además de excluirlos del cálculo. Para alternarlo temporalmente, busca el botón del ojo en Detalles del presupuesto y Detalles de la tarjeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans Réglages > Général > Affichage des dépenses, il est maintenant possible de masquer les dépenses futures à l’écran, ainsi que de les exclure des calculs. Pour le basculer temporairement, cherchez le bouton œil dans Détails du budget et Détails de la carte."
          }
        }
      }
    },
    "Two New Home Screen Widgets": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Two New Home Screen Widgets"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dos widgets nuevos para la pantalla de inicio"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Deux nouveaux widgets d’écran d’accueil"
          }
        }
      }
    },
    "Next Planned Expense and Spend Trends widgets are now available for the Home Screen. The Large and XXL Spend Trends widgets also incorporate Category Spotlight elements, showing spending by category as a percentage.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next Planned Expense and Spend Trends widgets are now available for the Home Screen. The Large and XXL Spend Trends widgets also incorporate Category Spotlight elements, showing spending by category as a percentage."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los widgets Próximo gasto planificado y Tendencias de gasto ya están disponibles para la pantalla de inicio. Los widgets Tendencias de gasto en tamaños Grande y XXL también incorporan elementos de Enfoque por categoría, mostrando el gasto por categoría como porcentaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les widgets Prochaine dépense planifiée et Tendances des dépenses sont maintenant disponibles pour l’écran d’accueil. Les widgets Tendances des dépenses en tailles Grande et XXL intègrent aussi des éléments Coup de projecteur sur la catégorie, en affichant les dépenses par catégorie en pourcentage."
          }
        }
      }
    },
    "Swept for Bugs": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swept for Bugs"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Barrido de errores"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chasse aux bugs"
          }
        }
      }
    },
    "Cleaned around the vault and managed to squash a few bugs and improve some UI glitches in the process.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cleaned around the vault and managed to squash a few bugs and improve some UI glitches in the process."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se limpió alrededor del cofre y se logró aplastar algunos errores y mejorar algunos fallos visuales de la interfaz en el proceso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un peu de nettoyage autour du coffre a permis d’écraser quelques bugs et d’améliorer au passage certains défauts visuels de l’interface."
          }
        }
      }
    },
    "Database Migration": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Database Migration"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Migración de la base de datos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Migration de la base de données"
          }
        }
      }
    },
    "Upgraded Offshore’s underlying data storage for a faster, more reliable experience. If you were part of the beta, you’ll need to delete the previous version before installing 2.2. This change sets Offshore up for smoother sailing long-term.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upgraded Offshore’s underlying data storage for a faster, more reliable experience. If you were part of the beta, you’ll need to delete the previous version before installing 2.2. This change sets Offshore up for smoother sailing long-term."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se actualizó el almacenamiento de datos interno de Offshore para ofrecer una experiencia más rápida y confiable. Si formaste parte de la beta, tendrás que eliminar la versión anterior antes de instalar la 2.2. Este cambio prepara a Offshore para navegar con más fluidez a largo plazo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le stockage de données sous-jacent d’Offshore a été amélioré pour offrir une expérience plus rapide et plus fiable. Si vous faisiez partie de la bêta, vous devrez supprimer la version précédente avant d’installer la 2.2. Ce changement prépare Offshore à une navigation plus fluide sur le long terme."
          }
        }
      }
    },
    "App-Wide Sparkle and Polish": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App-Wide Sparkle and Polish"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Brillo y pulido en toda la app"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Finition et polissage dans toute l’app"
          }
        }
      }
    },
    "Small but noticeable app-wide improvements. The app will still feel instantly familiar, just with a more refined and timeless look.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Small but noticeable app-wide improvements. The app will still feel instantly familiar, just with a more refined and timeless look."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pequeñas pero notables mejoras en toda la app. La app seguirá sintiéndose familiar al instante, solo que con un aspecto más refinado y atemporal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "De petites améliorations mais bien perceptibles dans toute l’app. L’application restera immédiatement familière, avec simplement une apparence plus raffinée et intemporelle."
          }
        }
      }
    },
    "Behind the Vault Improvements": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Behind the Vault Improvements"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoras entre bastidores"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorations en coulisses"
          }
        }
      }
    },
    "Reinforced the vault for Offshore’s future, and cleared out a few barnacles so everything runs a bit faster.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinforced the vault for Offshore’s future, and cleared out a few barnacles so everything runs a bit faster."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se reforzó el cofre para el futuro de Offshore y se quitaron algunos percebes para que todo funcione un poco más rápido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le coffre a été renforcé pour l’avenir d’Offshore et quelques bernacles ont été retirées pour que tout fonctionne un peu plus vite."
          }
        }
      }
    },
    "Improvements to Importing Expenses": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Improvements to Importing Expenses"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoras en la importación de gastos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorations de l’importation des dépenses"
          }
        }
      }
    },
    "Incoming entries now come in with cleaner names instead of long strings of bank text. You can store preferred names locally so future imports recognize them automatically with the press of a toggle.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Incoming entries now come in with cleaner names instead of long strings of bank text. You can store preferred names locally so future imports recognize them automatically with the press of a toggle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los movimientos importados ahora llegan con nombres más limpios en lugar de largas cadenas de texto bancario. Puedes guardar nombres preferidos localmente para que futuras importaciones los reconozcan automáticamente con solo activar un interruptor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées importées arrivent maintenant avec des noms plus propres au lieu de longues chaînes de texte bancaire. Vous pouvez enregistrer localement des noms préférés pour que les prochaines importations les reconnaissent automatiquement avec un simple interrupteur."
          }
        }
      }
    },
    "Import Entries": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import Entries"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importar movimientos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importer des entrées"
          }
        }
      }
    },
    "Import entries and income (.csv only) directly into a card from its detail view. Select what you want, then attach them instantly.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import entries and income (.csv only) directly into a card from its detail view. Select what you want, then attach them instantly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa movimientos e ingresos (.csv solamente) directamente a una tarjeta desde su vista de detalle. Selecciona lo que quieras y adjúntalo al instante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importez des entrées et des revenus (.csv uniquement) directement dans une carte depuis sa vue détaillée. Sélectionnez ce que vous voulez, puis attachez-les instantanément."
          }
        }
      }
    },
    "Customizable Card Appearances and Effects": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Customizable Card Appearances and Effects"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apariencias y efectos de tarjetas personalizables"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apparences et effets de carte personnalisables"
          }
        }
      }
    },
    "Updated the Card creation form with a new Effects feature. Find the perfect effect to pair with your Card’s theme.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Updated the Card creation form with a new Effects feature. Find the perfect effect to pair with your Card’s theme."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se actualizó el formulario de creación de tarjetas con una nueva función de efectos. Encuentra el efecto perfecto para combinar con el tema de tu tarjeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le formulaire de création de carte a été mis à jour avec une nouvelle fonction d’effets. Trouvez l’effet parfait à associer au thème de votre carte."
          }
        }
      }
    },
    "Accessibility Improvements": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility Improvements"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoras de accesibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorations de l’accessibilité"
          }
        }
      }
    },
    "App-wide accessibility updates, including Dynamic Type support and improved contrast. The Home grid was simplified to ensure full compliance.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App-wide accessibility updates, including Dynamic Type support and improved contrast. The Home grid was simplified to ensure full compliance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualizaciones de accesibilidad en toda la app, incluyendo compatibilidad con Dynamic Type y mejor contraste. La cuadrícula de Panel se simplificó para garantizar el cumplimiento completo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mises à jour de l’accessibilité dans toute l’app, avec prise en charge de la taille dynamique du texte et contraste amélioré. La grille Accueil a été simplifiée pour garantir une conformité complète."
          }
        }
      }
    },
    "Offshore Released to the Public": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Offshore Released to the Public"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Offshore se lanza al público"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Offshore est disponible publiquement"
          }
        }
      }
    },
    "The vault is officially ready for its first Offshore account!": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The vault is officially ready for its first Offshore account!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El cofre está oficialmente listo para su primera cuenta de Offshore."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le coffre est officiellement prêt pour son premier compte Offshore !"
          }
        }
      }
    },
    "Widgets In and Out of the App": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Widgets In and Out of the App"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Widgets dentro y fuera de la app"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des widgets dans et hors de l’app"
          }
        }
      }
    },
    "Track the metrics you care about most. Home is your dedicated budget dashboard, pin and reorder widgets to your liking. You can also pin select metrics on your iOS/macOS Home Screen.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track the metrics you care about most. Home is your dedicated budget dashboard, pin and reorder widgets to your liking. You can also pin select metrics on your iOS/macOS Home Screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue las métricas que más te importan. Panel es tu tablero dedicado de presupuesto; fija y reordena widgets a tu gusto. También puedes fijar métricas seleccionadas en la pantalla de inicio de iOS/macOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les indicateurs qui vous importent le plus. Accueil est votre tableau de bord budgétaire dédié ; épinglez et réorganisez les widgets comme vous le souhaitez. Vous pouvez aussi épingler certains indicateurs sur l’écran d’accueil iOS/macOS."
          }
        }
      }
    },
    "Polished the Vault Inside and Out": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Polished the Vault Inside and Out"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulido del cofre por dentro y por fuera"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le coffre a été peaufiné de fond en comble"
          }
        }
      }
    },
    "From the early days of landing on this deserted island to now, the app has been refined and polished throughout. Identity and brand have been set to sustain.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the early days of landing on this deserted island to now, the app has been refined and polished throughout. Identity and brand have been set to sustain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde los primeros días de aterrizar en esta isla desierta hasta ahora, la app se ha refinado y pulido por completo. La identidad y la marca quedaron establecidas para perdurar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Depuis les premiers jours passés à accoster sur cette île déserte jusqu’à maintenant, l’app a été affinée et peaufinée de bout en bout. Son identité et sa marque sont désormais posées pour durer."
          }
        }
      }
    },
    "Set Sail to Find Better Waters": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set Sail to Find Better Waters"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Zarpamos en busca de mejores aguas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre les voiles vers de meilleures eaux"
          }
        }
      }
    },
    "Embarked on a journey to create a budgeting app that values privacy, simplicity, and creative solutions. Dreamed day and night of an app that helps track and plan income, log expenses and understand spending, and build better habits to increase savings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Embarked on a journey to create a budgeting app that values privacy, simplicity, and creative solutions. Dreamed day and night of an app that helps track and plan income, log expenses and understand spending, and build better habits to increase savings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Emprendimos el viaje para crear una app de presupuesto que valore la privacidad, la simplicidad y las soluciones creativas. Soñamos día y noche con una app que ayude a seguir y planificar ingresos, registrar gastos y entender el gasto, y construir mejores hábitos para aumentar el ahorro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons embarqué dans l’aventure de créer une application de budget qui valorise la confidentialité, la simplicité et les solutions créatives. Nous avons rêvé jour et nuit d’une app qui aide à suivre et planifier les revenus, enregistrer les dépenses et comprendre les habitudes de dépense, afin de construire de meilleures habitudes pour augmenter l’épargne."
          }
        }
      }
    }
  },
  "version": "1.0"
}
