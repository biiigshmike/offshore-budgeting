    },
    "Split amount must be 0 or greater and cannot exceed the expense amount." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب أن يكون مبلغ التقسيم 0 أو أكبر ولا يمكن أن يتجاوز مبلغ النفقات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der aufgeteilte Betrag muss 0 oder größer sein und darf den Ausgabenbetrag nicht überschreiten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monto dividido debe ser 0 o mayor y no puede superar el monto del gasto."
          }
        },
        "fr" : {
