    "What If" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماذا إذا"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What If"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What If"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What If"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What If"
          }
        },
        "pt-BR" : {
