    "Save and test the new layout, then make small tweaks until the flow feels natural." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احفظ التصميم الجديد واختبره، ثم قم بإجراء تعديلات صغيرة حتى يبدو التدفق طبيعيًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speichern und testen Sie das neue Layout und nehmen Sie dann kleine Änderungen vor, bis sich der Ablauf natürlich anfühlt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save and test the new layout, then make small tweaks until the flow feels natural."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda y prueba el nuevo diseño, y luego haz pequeños ajustes hasta que el flujo se sienta natural."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
