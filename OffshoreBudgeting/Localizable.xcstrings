    },
    "This deletes the budget only. Any remaining expenses stay on their cards." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي هذا إلى حذف الميزانية فقط. أي نفقات متبقية تبقى على بطاقاتهم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch wird nur das Budget gelöscht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto solo elimina el presupuesto. Los gastos restantes se quedan en sus cuentas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime uniquement le budget. Les dépenses restantes restent sur leurs cartes."
