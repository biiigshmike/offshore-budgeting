    },
    "Notifications are currently off at the system level. Turn them on in Settings, then come back here." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإشعارات متوقفة حاليًا على مستوى النظام. قم بتفعيلها في الإعدادات، ثم عد إلى هنا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen sind derzeit auf Systemebene deaktiviert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones estan desactivadas a nivel del sistema. Activalas en Ajustes y vuelve aqui."
          }
        },
        "fr" : {
