    },
    "Quick Actions" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إجراءات سريعة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnelle Aktionen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Actions"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acciones rápidas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actions rapides"
          }
        }
      }
    },
    "Quick Actions are optional Apple Shortcuts that make repeat tasks faster. Offshore works fully without them, so treat automations as a convenience layer.\n\nFor Tap-to-Pay logging, setup is per device. Build and test the automation on each device where you want it to run." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإجراءات السريعة هي اختصارات Apple اختيارية تجعل المهام المتكررة أسرع. تعمل Offshore بشكل كامل بدونها، لذا تعامل مع عمليات التشغيل الآلي كطبقة ملائمة.\n\nبالنسبة لتسجيل النقر للدفع، يتم الإعداد لكل جهاز. قم ببناء واختبار الأتمتة على كل جهاز تريد تشغيله فيه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnellaktionen sind optionale Apple-Verknüpfungen, die sich wiederholende Aufgaben beschleunigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Actions are optional Apple Shortcuts that make repeat tasks faster. Offshore works fully without them, so treat automations as a convenience layer.\n\nFor Tap-to-Pay logging, setup is per device. Build and test the automation on each device where you want it to run."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las Acciones rápidas son Atajos de Apple opcionales que hacen más rápidas las tareas repetidas. Offshore funciona por completo sin ellas, así que trata las automatizaciones como una capa de conveniencia.\n\nPara el registro con Tap to Pay, la configuración es por dispositivo. Crea y prueba la automatización en cada dispositivo donde quieras usarla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les actions rapides sont des Raccourcis Apple facultatifs qui accélèrent les tâches répétitives. Offshore fonctionne entièrement sans elles, alors considérez les automatisations comme une simple couche de confort.\n\nPour la journalisation Tap to Pay, la configuration se fait appareil par appareil. Créez et testez l’automatisation sur chaque appareil où vous voulez l’utiliser."
          }
        }
      }
    },
    "Quick Actions is the install hub for Offshore shortcut links. For Tap-to-Pay, use Apple Shortcuts Transaction automation and Offshore Add Expense intent.\n\nSetup is per device." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإجراءات السريعة هي مركز التثبيت لروابط اختصارات Offshore. بالنسبة إلى ميزة النقر للدفع، استخدم أتمتة المعاملات باستخدام اختصارات Apple وOffshore إضافة غرض النفقات.\n\nالإعداد لكل جهاز."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Actions ist der Installations-Hub für Offshore-Verknüpfungslinks."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Actions is the install hub for Offshore shortcut links. For Tap-to-Pay, use Apple Shortcuts Transaction automation and Offshore Add Expense intent.\n\nSetup is per device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acciones rápidas es el centro de instalación de enlaces de atajos de Offshore. Para Tap to Pay, usa la automatización de transacciones de Atajos de Apple y la intención Offshore Add Expense.\n\nLa configuración es por dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actions rapides est le centre d’installation des liens de raccourcis Offshore. Pour Tap to Pay, utilisez l’automatisation de transaction de Raccourcis Apple et l’intention Offshore Add Expense.\n\nLa configuration se fait appareil par appareil."
          }
        }
      }
    },
