    },
    "A private, manual-first way to plan your money.\nNo bank connections or accounts required." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "طريقة خاصة يدوية لتخطيط أموالك.\nلا توجد اتصالات مصرفية أو حسابات مطلوبة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine private, manuelle Möglichkeit, Ihr Geld zu planen.\nKeine Bankverbindungen oder Konten erforderlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una forma privada y manual de planificar tu dinero.\nNo se requieren conexiones bancarias ni cuentas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une façon privée, centrée sur le manuel, de planifier votre argent.\nAucune connexion bancaire ni compte requis."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma maneira privada e manual de planejar seu dinheiro.\nNão são necessárias conexões bancárias ou contas."
