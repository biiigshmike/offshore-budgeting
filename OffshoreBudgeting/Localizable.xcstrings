    "notification.dailyExpense.body": {
      "comment": "Daily reminder notification body for logging expenses.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the books tidy and balanced. Log any variable expenses today."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén tus cuentas ordenadas y equilibradas. Registra hoy tus gastos variables."
