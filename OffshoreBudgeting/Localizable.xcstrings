          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开始日期必须等于或早于结束日期。"
          }
        }
      }
    },
    "Start Excursion Mode" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابدأ وضع الرحلة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starten Sie den Ausflugsmodus"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Start Excursion Mode"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iniciar modo Excursion"
          }
        },
        "fr" : {
          "stringUnit" : {
