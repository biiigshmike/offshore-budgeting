            "value" : "Carte requise"
          }
        }
      }
    },
    "Card Unavailable" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "البطاقة غير متاحة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karte nicht verfügbar"
          }
        },
        "es" : {
