    "homeWidget.spendTrends.cardHint" : {
      "comment" : "Accessibility hint for selecting a card in spend trends.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر نقرًا مزدوجًا لتصفية اتجاهات الإنفاق لهذه البطاقة. اضغط مرة أخرى للمسح والعودة إلى الفترة P."
