        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes cambiar esto más tarde en Ingresos."
          }
        }
      }
    },
    "You can delete the budget now, or tap Done to keep it.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes eliminar el presupuesto ahora o tocar Listo para conservarlo."
          }
        }
      }
    },
    "You can finish now, or create a starter budget so Home has planning context right away.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes terminar ahora o crear un presupuesto inicial para que el panel tenga contexto de planificación de inmediato."
          }
        }
      }
    },
    "You can restart onboarding at any time.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes reiniciar el onboarding en cualquier momento."
          }
