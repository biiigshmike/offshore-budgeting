    "budgetDetail.categories.footer" : {
      "comment" : "Footer guidance for budget detail category chips.",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فئات الضغط الواحد لتصفية النفقات؛ اضغط على الرقائق المحددة لمسح واحدة. اضغط لفترة طويلة لتعديل حدود الفئات."
