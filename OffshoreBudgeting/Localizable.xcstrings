            "value": "Expérience de bienvenue"
          }
        }
      }
    },
    "The onboarding process now supports setting up the entire budgeting workspace. Previously, only select features were configured during onboarding.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The onboarding process now supports setting up the entire budgeting workspace. Previously, only select features were configured during onboarding."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El proceso de bienvenida ahora permite configurar todo el espacio de trabajo de presupuestos. Antes, solo se configuraban algunas funciones durante la bienvenida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le parcours de bienvenue permet maintenant de configurer tout l’espace de travail budgétaire. Auparavant, seules certaines fonctions étaient configurées pendant la bienvenue."
          }
        }
      }
    },
    "Excursion Mode has been refined to deliver more precise notifications near relevant points of interest, while still processing everything 100% on-device.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Excursion Mode has been refined to deliver more precise notifications near relevant points of interest, while still processing everything 100% on-device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El Modo Excursión se ha refinado para ofrecer notificaciones más precisas cerca de puntos de interés relevantes, mientras todo sigue procesándose 100% en el dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode Excursion a été affiné pour offrir des notifications plus précises près des points d’intérêt pertinents, tout en traitant toujours tout 100 % sur l’appareil."
          }
        }
      }
    },
    "What If? Scenario Planner": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What If? Scenario Planner"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Planificador de escenarios What If?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Planificateur de scénarios What If ?"
          }
        }
      }
    },
    "The What If? planner now supports using income in scenarios, instead of only adjusting spending by category. The planner also loads with the current period’s minimum and maximum category caps from active budgets, and includes a field to enter a desired scenario value.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The What If? planner now supports using income in scenarios, instead of only adjusting spending by category. The planner also loads with the current period’s minimum and maximum category caps from active budgets, and includes a field to enter a desired scenario value."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El planificador What If? ahora permite usar ingresos en los escenarios, en lugar de solo ajustar el gasto por categoría. También carga los límites mínimo y máximo de categoría del periodo actual desde los presupuestos activos, e incluye un campo para ingresar un valor deseado para el escenario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le planificateur What If ? permet maintenant d’utiliser les revenus dans les scénarios, au lieu de seulement ajuster les dépenses par catégorie. Il se charge aussi avec les plafonds minimum et maximum des catégories de la période en cours depuis les budgets actifs, et inclut un champ pour saisir une valeur de scénario souhaitée."
          }
        }
      }
    },
    "Improvements to Reconciliations": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Improvements to Reconciliations"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejoras en las conciliaciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorations des rapprochements"
          }
        }
      }
    },
    "Addresses an issue where offsetting an expense via a Reconciliation account would not allow the full available amount to be used.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Addresses an issue where offsetting an expense via a Reconciliation account would not allow the full available amount to be used."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Corrige un problema por el que compensar un gasto mediante una cuenta de conciliación no permitía usar el monto disponible completo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Corrige un problème où la compensation d’une dépense via un compte de rapprochement ne permettait pas d’utiliser la totalité du montant disponible."
          }
        }
      }
    },
    "The Savings Account graph now offers two views: Running Total and Current Period.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Savings Account graph now offers two views: Running Total and Current Period."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La gráfica de la Cuenta de ahorros ahora ofrece dos vistas: total acumulado y periodo actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le graphique du compte d’épargne propose maintenant deux vues : total cumulé et période en cours."
          }
        }
      }
    },
    "Swipe to Edit or Delete": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe to Edit or Delete"
          }
