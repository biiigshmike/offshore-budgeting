    "Category Spotlight" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تسليط الضوء على الفئة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kategorie-Spotlight"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Category Spotlight"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Categoría destacada"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Catégorie en vedette"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destaque da categoria"
          }
        },
        "zh-Hans" : {
