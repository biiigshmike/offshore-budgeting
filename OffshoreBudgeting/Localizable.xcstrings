    "Step 1: Open Automation and start a new automation." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الخطوة 1: افتح الأتمتة وابدأ عملية أتمتة جديدة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schritt 1: Öffnen Sie die Automatisierung und starten Sie eine neue Automatisierung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Step 1: Open Automation and start a new automation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
