    "Savings offset amount must be 0 or greater and cannot exceed the planned amount." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب أن يكون مبلغ مقاصة الادخار 0 أو أكبر، ولا يمكن أن يتجاوز المبلغ المخطط له."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Sparverrechnungsbetrag muss 0 oder größer sein und darf den geplanten Betrag nicht überschreiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Savings offset amount must be 0 or greater and cannot exceed the planned amount."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El importe del ajuste de ahorros debe ser 0 o mayor y no puede superar el importe planificado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le montant de compensation de l’épargne doit être supérieur ou égal à 0 et ne peut pas dépasser le montant prévu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O valor da compensacao da poupanca deve ser 0 ou maior e nao pode exceder o valor planejado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "储蓄抵扣金额必须大于或等于 0，且不能超过计划金额。"
          }
        }
      }
    },
    "Savings offset amount must be 0 or greater, cannot exceed planned amount, and cannot exceed available savings." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب أن يكون مبلغ تعويض التوفير 0 أو أكبر، ولا يمكن أن يتجاوز المبلغ المخطط، ولا يمكن أن يتجاوز المدخرات المتاحة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Ersparnisausgleichsbetrag muss 0 oder größer sein, darf den geplanten Betrag nicht überschreiten und darf die verfügbaren Ersparnisse nicht überschreiten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monto de ajuste con ahorros debe ser 0 o mayor, no puede superar el monto planificado ni los ahorros disponibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épargne offset amount must be 0 or greater, cannot exceed planned amount, and cannot exceed available savings."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O valor da compensação de poupança deve ser 0 ou superior, não pode exceder o valor planejado e não pode exceder a economia disponível."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "储蓄抵消金额必须为 0 或更大，不能超过计划金额，也不能超过可用储蓄。"
          }
        }
      }
    },
    "Savings offset must be 0 or greater and cannot exceed the expense amount." : {
