        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie zweimal, um die Ausgabentrends für diese Karte zu filtern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Double tap to filter spend trends to this card. Tap again to clear and return to period P."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca dos veces para filtrar tendencias por esta tarjeta. Toca de nuevo para limpiar y volver al período P."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez deux fois pour filtrer les tendances de dépenses sur cette carte. Touchez de nouveau pour effacer et revenir à la période P."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque duas vezes para filtrar tendências de gastos neste cartão. Toque novamente para limpar e retornar ao período P."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
