    "Return projected end-of-month savings and an overspend warning when applicable." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بإرجاع المدخرات المتوقعة في نهاية الشهر وتحذير من الإنفاق الزائد عند الاقتضاء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geben Sie die prognostizierten Einsparungen zum Monatsende und ggf. eine Warnung zu Mehrausgaben zurück."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Devuelve el ahorro proyectado de fin de mes y una alerta de sobregasto cuando corresponda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return projected end-de-month savings and an overspend warning when applicable."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retorne as economias projetadas para o final do mês e um aviso de gastos excessivos, quando aplicável."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "返回预计的月末节省金额并在适用时发出超支警告。"
          }
        }
      }
    },
    "Review %@" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مراجعة %@"
          }
        },
        "de" : {
