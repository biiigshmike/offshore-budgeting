            "value" : "Créez des catégories pour organiser les dépenses et les préréglages."
          }
        }
      }
    },
    "Create New" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إنشاء جديد"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neu erstellen"
          }
        },
        "es" : {
