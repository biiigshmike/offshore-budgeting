    "Tap To Pay automation setup steps are currently available on iPhone only.\n\nOpen this help topic on iPhone to view the full step-by-step setup walkthrough." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتوفر خطوات إعداد أتمتة Tap To Pay حاليًا على iPhone فقط.\n\nافتح موضوع المساعدة هذا على iPhone لعرض إرشادات الإعداد الكاملة خطوة بخطوة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Schritte zur Einrichtung der Tap-To-Pay-Automatisierung sind derzeit nur auf dem iPhone verfügbar.\n\nÖffnen Sie dieses Hilfethema auf dem iPhone, um die vollständige Schritt-für-Schritt-Anleitung zur Einrichtung anzuzeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap To Pay automation setup steps are currently available on iPhone only.\n\nOpen this help topic on iPhone to view the full step-by-step setup walkthrough."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los pasos de configuración de automatización de Tap to Pay están disponibles actualmente solo en iPhone.\n\nAbre este tema de ayuda en iPhone para ver la guía completa paso a paso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les étapes de configuration de l’automatisation Tap to Pay sont actuellement disponibles uniquement sur iPhone.\n\nOuvrez cette rubrique d’aide sur iPhone pour voir le guide complet pas à pas."
          }
        }
      }
    },
