    "Planned Expense Pitfalls" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مخاطر النفقات المخططة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fallstricke bei geplanten Ausgaben"
          }
        },
        "en" : {
