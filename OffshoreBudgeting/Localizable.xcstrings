    "Presets" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإعدادات المسبقة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voreinstellungen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Presets"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plantillas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Préréglages"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Predefinições"
          }
        },
        "zh-Hans" : {
