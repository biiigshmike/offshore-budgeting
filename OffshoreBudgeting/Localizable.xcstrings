    "Use Presets management to keep recurring templates accurate and ready." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم إدارة الإعدادات المسبقة للحفاظ على دقة القوالب المتكررة وجاهزيتها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutzen Sie die Voreinstellungsverwaltung, um wiederkehrende Vorlagen korrekt und bereit zu halten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Presets management to keep recurring templates accurate and ready."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa la gestión de Plantillas para mantener listas y precisas las plantillas recurrentes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez la gestion des Préréglages pour garder les modèles récurrents exacts et prêts."
          }
