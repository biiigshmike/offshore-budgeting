    "Shows Excursion Mode status and timing on your Lock Screen while the session is active." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعرض حالة وضع الرحلة والتوقيت على شاشة القفل الخاصة بك أثناء تنشيط الجلسة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt den Status und das Timing des Ausflugsmodus auf Ihrem Sperrbildschirm an, während die Sitzung aktiv ist."
          }
        },
        "en" : {
          "stringUnit" : {
