            "value" : "قم باستيراد سجلات CSV/PDF/الصور، واستخدم ذاكرة التعيين للتكرارات، وتجنب صفوف نفقات تحويل الدفع."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importieren Sie CSV-/PDF-/Bilddatensätze, nutzen Sie den Zuordnungsspeicher für Wiederholungen und vermeiden Sie Ausgabenzeilen für Zahlungsübertragungen."
          }
        },
        "en" : {
          "stringUnit" : {
