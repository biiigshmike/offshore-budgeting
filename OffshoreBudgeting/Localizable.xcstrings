    "If presets stay linked to this budget, they may apply again when you re-link this card." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا ظلت الإعدادات المسبقة مرتبطة بهذه الميزانية، فقد يتم تطبيقها مرة أخرى عند إعادة ربط هذه البطاقة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Voreinstellungen mit diesem Budget verknüpft bleiben, gelten sie möglicherweise erneut, wenn Sie diese Karte erneut verknüpfen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si los plantillas siguen vinculados a este presupuesto, pueden aplicarse de nuevo al volver a vincular esta cuenta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si les préréglages restent liés à ce budget, ils pourront s’appliquer de nouveau lorsque vous relierez cette carte."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se as predefinições permanecerem vinculadas a esse orçamento, elas poderão ser aplicadas novamente quando você vincular novamente este cartão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果预设与此预算保持关联，则当您重新关联此卡时，它们可能会再次应用。"
          }
        }
      }
    },
    "If you want to review Photos access, open %@." : {
