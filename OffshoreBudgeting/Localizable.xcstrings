    "Offset amount must be 0 or greater and cannot exceed the expense amount." : {
      "comment" : "An alert message displayed when the offset amount entered by the user is invalid.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب أن يكون مبلغ المقاصة 0 أو أكبر، ولا يمكن أن يتجاوز مبلغ المصروف."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Verrechnungsbetrag muss 0 oder größer sein und darf den Ausgabenbetrag nicht überschreiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Offset amount must be 0 or greater and cannot exceed the expense amount."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El importe del ajuste debe ser 0 o mayor y no puede superar el importe del gasto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le montant de compensation doit être supérieur ou égal à 0 et ne peut pas dépasser le montant de la dépense."
          }
        },
        "pt-BR" : {
