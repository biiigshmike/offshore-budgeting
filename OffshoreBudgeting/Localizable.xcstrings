    "home.tip.dateRange.detail" : {
      "comment" : "Home tip detail for date range controls.",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم عناصر التحكم في التاريخ في الجزء العلوي لتغيير الفترة الزمنية المعروضة عبر جميع الأدوات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie die Datumssteuerelemente oben, um den in allen Widgets angezeigten Zeitraum zu ändern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Use the date controls at the top to change the time period shown across all widgets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Usa los controles de fecha de arriba para cambiar el periodo mostrado en todos los paneles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez les contrôles de date en haut pour modifier la période affichée sur tous les widgets."
