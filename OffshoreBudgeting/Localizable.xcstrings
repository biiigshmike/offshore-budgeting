    "Are you sure you want to clear your chat history?" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد مسح سجل الدردشة الخاص بك؟"
          }
        },
        "de" : {
          "stringUnit" : {
