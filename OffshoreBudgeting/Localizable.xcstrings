            "state" : "translated",
            "value" : "使用预设管理来保持重复模板的准确性和就绪性。"
          }
        }
      }
    },
    "Use Reconciliations to track shared balances separately from normal card spending." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم التسويات لتتبع الأرصدة المشتركة بشكل منفصل عن الإنفاق العادي بالبطاقة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie Abstimmungen, um gemeinsame Guthaben getrennt von den normalen Kartenausgaben zu verfolgen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Reconciliations to track shared balances separately from normal card spending."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa Conciliaciones para seguir saldos compartidos por separado del gasto normal de tarjeta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez les Rapprochements pour suivre les soldes partagés séparément des dépenses normales de carte."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Reconciliações para rastrear saldos compartilhados separadamente dos gastos normais do cartão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用对账来跟踪与正常卡支出分开的共享余额。"
          }
        }
      }
    },
    "Use Savings Outlook to forecast direction and course-correct before period close." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم Savings Outlook للتنبؤ بالاتجاه وتصحيح المسار قبل إغلاق الفترة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie den Savings Outlook, um die Richtung vorherzusagen und den Kurs vor Periodenende zu korrigieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Savings Outlook to forecast direction and course-correct before period close."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa Perspectiva de ahorro para prever la dirección y corregir el rumbo antes del cierre del periodo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez Perspective d’épargne pour anticiper la direction et corriger la trajectoire avant la clôture de la période."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
