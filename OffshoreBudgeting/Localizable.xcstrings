        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen sind derzeit für Offshore deaktiviert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones de Offshore estan desactivadas. Puedes activarlas en Ajustes."
          }
        },
        "fr" : {
