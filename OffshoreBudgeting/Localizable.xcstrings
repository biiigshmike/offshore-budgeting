    "Tap To Pay: Controlled Setup" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط للدفع: الإعداد المتحكم فيه"
          }
        },
        "de" : {
