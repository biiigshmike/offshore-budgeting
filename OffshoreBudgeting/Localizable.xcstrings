    "Reset & Erase Content applies to on-device data. You’re currently using iCloud, so you’ll need to switch to On Device and restart first." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنطبق إعادة تعيين ومسح المحتوى على البيانات الموجودة على الجهاز. أنت تستخدم حاليًا iCloud، لذا ستحتاج إلى التبديل إلى \"على الجهاز\" وإعادة التشغيل أولاً."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Inhalt zurücksetzen und löschen“ gilt für Daten auf dem Gerät."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restablecer y borrar contenido se aplica a datos del dispositivo. Actualmente usas iCloud, asi que debes cambiar a En este dispositivo y reiniciar primero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réinitialiser et effacer le contenu s’applique aux données sur l’appareil. Vous utilisez actuellement iCloud, vous devrez donc passer à Sur l’appareil et redémarrer d’abord."
          }
        }
      }
    },
