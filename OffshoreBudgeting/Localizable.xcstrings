    "Notifications Disabled" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإخطارات معطلة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen deaktiviert"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notificaciones desactivadas"
          }
        },
        "fr" : {
          "stringUnit" : {
