    "Reconciliations and Savings: Now on the Accounts Tab" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التسويات والادخار: الآن في علامة التبويب \"الحسابات\"."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abstimmungen und Einsparungen: Jetzt auf der Registerkarte „Konten“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliations and Savings: Now on the Accounts Tab"
          }
        },
        "es" : {
