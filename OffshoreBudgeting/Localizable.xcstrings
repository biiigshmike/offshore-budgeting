          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können das Budget jetzt löschen oder auf „Fertig“ tippen, um es beizubehalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
