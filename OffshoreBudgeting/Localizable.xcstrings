    "assistant.persona.transitionDescription" : {
      "comment" : "Introductory Marina description shown in the empty assistant state.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سأساعدك على البقاء متشجعًا ومستقرًا من خلال قراءات سريعة وعملية حول إنفاقك واتجاهاتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich helfe dir, motiviert und geerdet zu bleiben, mit schnellen, praktischen Einblicken in deine Ausgaben und Trends."
