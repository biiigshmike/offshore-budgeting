            "value" : "أضف الإعدادات المسبقة الآن، أو قم بتخطيها وإضافتها لاحقًا من شاشة الإعدادات المسبقة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügen Sie jetzt Voreinstellungen hinzu oder überspringen Sie die Voreinstellungen und fügen Sie sie später über den Bildschirm „Voreinstellungen“ hinzu."
          }
        },
        "es" : {
