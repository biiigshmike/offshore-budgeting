    "This Apple ID can sync existing Offshore data from iCloud. You can always switch later from Manage Workspaces." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن لمعرف Apple هذا مزامنة بيانات Offshore الموجودة من iCloud. يمكنك دائمًا التبديل لاحقًا من إدارة مساحات العمل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Apple-ID kann vorhandene Offshore-Daten von iCloud synchronisieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este Apple ID puede sincronizar datos existentes de Offshore desde iCloud. Siempre puedes cambiarlo después en Gestionar Espacios de Trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This Apple ID can sync existing Offshore data from iCloud. You can always switch later from Manage Espaces de travail."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este ID Apple pode sincronizar dados Offshore existentes do iCloud. Você sempre pode alternar posteriormente em Gerenciar espaços de trabalho."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此 Apple ID 可以同步 iCloud 中现有的 Offshore 数据。您以后随时可以从“管理工作区”进行切换。"
          }
        }
      }
    },
    "This budget created planned expenses on your cards. What should Offshore do with them?" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خلقت هذه الميزانية نفقات مخططة على بطاقاتك. ماذا يجب أن يفعل Offshore معهم؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch dieses Budget wurden geplante Ausgaben auf Ihren Karten erstellt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este presupuesto creo gastos planificados en tus cuentas. Que debe hacer Offshore con ellos?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce budget a créé des dépenses prévues sur vos cartes. Que doit faire Offshore avec elles ?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este orçamento criou despesas planejadas em seus cartões. O que o Offshore deve fazer com eles?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "该预算在您的卡上创建了计划支出。 Offshore 应该如何处理它们？"
          }
        }
      }
    },
    "This cannot be undone." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يمكن التراجع عن هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action est irréversible."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto não pode ser desfeito."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此操作无法撤消。"
          }
        }
