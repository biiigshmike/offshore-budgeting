    "Double tap to filter spend trends to this card. Tap again to clear and return to period P." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر نقرًا مزدوجًا لتصفية اتجاهات الإنفاق لهذه البطاقة. اضغط مرة أخرى للمسح والعودة إلى الفترة P."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie zweimal, um die Ausgabentrends für diese Karte zu filtern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca dos veces para filtrar tendencias de gasto en esta tarjeta. Toca de nuevo para limpiar y volver al período P."
          }
        },
        "fr" : {
