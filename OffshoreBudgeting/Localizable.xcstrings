    "Get your current month remaining budget, a category remaining amount, and a safe daily spend amount." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احصل على ميزانيتك المتبقية للشهر الحالي، والمبلغ المتبقي للفئة، ومبلغ الإنفاق اليومي الآمن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalten Sie Ihr aktuelles Monatsbudget, einen Restbetrag für die Kategorie und einen sicheren Tagesausgabenbetrag."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obtén el presupuesto restante del mes actual, el restante por categoría y un monto diario seguro para gastar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obtenez votre budget restant du mois en cours, le montant restant d’une catégorie et un montant de dépense quotidien sûr."
          }
        }
      }
    },
    "Getting Started" : {
