          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie Arbeitsbereiche, um Kontexte getrennt zu halten und eine domänenübergreifende Datenvermischung zu verhindern."
          }
        },
        "en" : {
