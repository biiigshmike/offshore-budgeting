        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restablecer y borrar contenido se aplica a datos del dispositivo. Actualmente usas iCloud, asi que debes cambiar a En este dispositivo y reiniciar primero."
          }
