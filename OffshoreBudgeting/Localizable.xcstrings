    "App-wide accessibility updates, including Dynamic Type support and improved contrast. The Home grid was simplified to ensure full compliance." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحديثات إمكانية الوصول على مستوى التطبيق، بما في ذلك دعم النوع الديناميكي والتباين المحسن. تم تبسيط الشبكة الرئيسية لضمان الامتثال الكامل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App-weite Aktualisierungen der Barrierefreiheit, einschließlich Dynamic Type-Unterstützung und verbessertem Kontrast."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App-wide accessibility updates, including Dynamic Type support and improved contrast. The Home grid was simplified to ensure full compliance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualizaciones de accesibilidad en toda la app, incluyendo compatibilidad con Dynamic Type y mejor contraste. La cuadrícula de Panel se simplificó para garantizar el cumplimiento completo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mises à jour de l’accessibilité dans toute l’app, avec prise en charge de la taille dynamique du texte et contraste amélioré. La grille Accueil a été simplifiée pour garantir une conformité complète."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atualizações de acessibilidade em todo o aplicativo, incluindo suporte para tipo dinâmico e contraste aprimorado. A grade inicial foi simplificada para garantir total conformidade."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用程序范围内的辅助功能更新，包括动态类型支持和改进的对比度。简化了家庭网格以确保完全合规。"
          }
        }
      }
    },
