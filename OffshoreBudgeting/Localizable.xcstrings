    "Use iCloud to sync your workspaces and budgets across your devices signed into this Apple ID." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم iCloud لمزامنة مساحات العمل والميزانيات الخاصة بك عبر أجهزتك المسجلة في معرف Apple هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie iCloud, um Ihre Arbeitsbereiche und Budgets auf allen Ihren mit dieser Apple-ID angemeldeten Geräten zu synchronisieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa iCloud para sincronizar tus espacios de trabajo y presupuestos entre tus dispositivos con este Apple ID."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
