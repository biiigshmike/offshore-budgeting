    "Add presets now, or skip and add them later from the Presets screen.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega plantillas ahora o omite y agrégalos después desde la pantalla de Plantillas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des préréglages maintenant, ou ignorez cette étape et ajoutez-les plus tard depuis l’écran Préréglages."
          }
        }
      }
    },
    "Add savings entries to start your running total trend.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega movimientos de ahorros para iniciar la tendencia de tu saldo acumulado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des entrées d’épargne pour démarrer votre tendance de total cumulé."
          }
        }
      }
    },
