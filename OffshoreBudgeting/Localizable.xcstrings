    },
    "Ask Marina for guidance, then use +, edit, or delete on the owning screen to complete the flow." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اطلب من Marina الحصول على إرشادات، ثم استخدم + أو تحرير أو حذف على الشاشة الخاصة لإكمال التدفق."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitten Sie Marina um Anleitung und verwenden Sie dann +, Bearbeiten oder Löschen auf dem Besitzerbildschirm, um den Ablauf abzuschließen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ask Marina for guidance, then use +, edit, or delete on the owning screen to complete the flow."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pídele orientación a Marina y luego usa +, editar o eliminar en la pantalla dueña para completar el flujo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demandez conseil à Marina, puis utilisez +, modifier ou supprimer sur l’écran propriétaire pour terminer le flux."
          }
        }
      }
    },
