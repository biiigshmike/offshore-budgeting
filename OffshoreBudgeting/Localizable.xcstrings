    "home.emptyPinned.message" : {
      "comment" : "Message when no home items are pinned.",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على \"تحرير\" لتثبيت الأدوات والبطاقات على الصفحة الرئيسية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie auf Bearbeiten, um Widgets und Karten an die Startseite anzuheften."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap Edit to pin widgets and cards to Home."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca Editar para fijar paneles y tarjetas en Panel."
          }
        },
        "fr" : {
