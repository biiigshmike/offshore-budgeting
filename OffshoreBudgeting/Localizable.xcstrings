            "value": "Opciones de escenario"
          }
        }
      }
    },
    "whatIf.scenarios": {
      "comment": "Section title listing available What If scenarios.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scenarios"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escenarios"
          }
        }
      }
    },
    "whatIf.unpinFromHome": {
      "comment": "Menu action to unpin selected scenario from Home.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unpin from Home"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quitar de Panel"
          }
        }
      }
    },
    "When enabled, planned expenses scheduled after today are excluded from totals and savings calculations.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, los gastos planificados posteriores a hoy se excluyen de totales y calculos de ahorro."
          }
        }
      }
    },
    "When enabled, planned expenses scheduled after today are hidden from expense lists.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, los gastos planificados posteriores a hoy se ocultan de las listas."
          }
        }
      }
    },
    "When enabled, the app will always launch with the last view you were on instead of defaulting to Home.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, la app siempre abrirá con la última vista usada en lugar de ir al panel."
          }
        }
      }
    },
    "When enabled, variable expenses dated after today are excluded from totals and savings calculations.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, los gastos variables posteriores a hoy se excluyen de totales y calculos de ahorro."
          }
        }
      }
    },
    "When enabled, variable expenses dated after today are hidden from expense lists.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, los gastos variables posteriores a hoy se ocultan de las listas."
          }
        }
      }
    },
    "When enabled, you’ll always be asked to confirm before anything is deleted.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, siempre se te pedira confirmar antes de eliminar cualquier cosa."
          }
        }
      }
    },
    "When enabled, you’ll be asked to authenticate whenever the app opens.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, se te pedira autenticarte cada vez que se abra la app."
          }
        }
      }
    },
    "When enabled, your budgets and entries sync across devices with the same Apple ID. When disabled, data stays only on this device.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, tus presupuestos y movimientos se sincronizan entre dispositivos con el mismo Apple ID. Cuando está desactivado, los datos se quedan solo en este dispositivo."
          }
        }
      }
    },
    "When Mixed Rows": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando hay filas mixtas"
          }
        }
      }
    },
    "When Repeat is set, you must also set an End Date (and it cannot be before the start date).": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando Repetir está activado, también debes definir una fecha de fin (y no puede ser anterior a la fecha de inicio)."
          }
        }
      }
    },
    "Which card should expense rows import into?": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿En qué tarjeta se deben importar las filas de gastos?"
          }
        }
      }
    },
    "Which card should this expense use?": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué tarjeta debe usar este gasto?"
          }
        }
      }
    },
    "Which category should this expense use?": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué categoría debe usar este gasto?"
          }
        }
      }
