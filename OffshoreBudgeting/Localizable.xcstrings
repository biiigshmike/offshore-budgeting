    "To manage Offshore’s iCloud storage, open the iOS Settings app and go to:\nApple ID → iCloud → Storage → Offshore Budgeting" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لإدارة مساحة تخزين iCloud الخاصة بـ Offshore، افتح تطبيق إعدادات iOS وانتقل إلى:\nمعرف Apple → iCloud → التخزين → ميزانية Offshore"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um den iCloud-Speicher von Offshore zu verwalten, öffnen Sie die iOS-Einstellungen-App und gehen Sie zu:\nApple-ID → iCloud → Speicher → Offshore Budgetierung"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para administrar el almacenamiento de iCloud de Offshore, abre la app Ajustes de iOS y ve a:\nApple ID → iCloud → Almacenamiento → Offshore Budgeting"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To manage Offshore’s iCloud storage, open the iOS Réglages app and go to:\nApple ID → iCloud → Storage → Offshore Budgeting"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para gerenciar o armazenamento iCloud do Offshore, abra o aplicativo Configurações do iOS e vá para:\nApple ID → iCloud → Armazenamento → Orçamento Offshore"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要管理 Offshore 的 iCloud 存储，请打开 iOS 设置应用程序并转至：\nApple ID → iCloud → 存储 → Offshore 预算"
          }
        }
      }
    },
    "To pass transaction amount and merchant details, tap the Amount field, choose Select Variable, then choose Shortcut Input." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لتمرير مبلغ المعاملة وتفاصيل التاجر، اضغط على حقل المبلغ، واختر تحديد متغير، ثم اختر إدخال الاختصار."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um den Transaktionsbetrag und die Händlerdetails zu übergeben, tippen Sie auf das Feld „Betrag“, wählen Sie „Variable auswählen“ und dann „Shortcut-Eingabe“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To pass transaction amount and merchant details, tap the Amount field, choose Select Variable, then choose Shortcut Input."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para pasar el importe de la transacción y los detalles del comercio, toca el campo Importe, elige Seleccionar variable y luego Entrada del atajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour transmettre le montant de la transaction et les détails du commerçant, touchez le champ Montant, choisissez Sélectionner une variable, puis Entrée du raccourci."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para passar o valor da transação e os detalhes do comerciante, toque no campo Valor, escolha Selecionar variável e escolha Entrada de atalho."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要传递交易金额和商户详细信息，请点击金额字段，选择选择变量，然后选择快捷方式输入。"
          }
        }
      }
    },
    "To use iCloud sync, sign in to iCloud in the Settings app, then return here and try again." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لاستخدام مزامنة iCloud، قم بتسجيل الدخول إلى iCloud في تطبيق الإعدادات، ثم قم بالعودة إلى هنا وحاول مرة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um die iCloud-Synchronisierung zu verwenden, melden Sie sich in der App „Einstellungen“ bei iCloud an, kehren Sie dann hierher zurück und versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar sincronizacion con iCloud, inicia sesion en iCloud en la app Ajustes y luego vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use iCloud sync, sign in to iCloud in the Réglages app, then return here and try again."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar a sincronização iCloud, faça login no iCloud no aplicativo Configurações, retorne aqui e tente novamente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要使用 iCloud 同步，请在“设置”应用中登录 iCloud，然后返回此处重试。"
