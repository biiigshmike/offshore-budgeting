    "Change the Amount field variable to Amount and tap Return. Repeat for Merchant by selecting the Merchant field, choosing Shortcut Input, and changing the variable to Merchant." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتغيير متغير حقل المبلغ إلى المبلغ ثم انقر فوق إرجاع. كرر ذلك مع التاجر عن طريق تحديد حقل التاجر، واختيار إدخال الاختصار، وتغيير المتغير إلى التاجر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändern Sie die Feldvariable „Betrag“ in „Betrag“ und tippen Sie auf „Zurückgeben“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change the Amount field variable to Amount and tap Return. Repeat for Merchant by selecting the Merchant field, choosing Shortcut Input, and changing the variable to Merchant."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia la variable del campo Importe a Importe y toca Retorno. Repite para Comercio seleccionando el campo Comercio, eligiendo Entrada del atajo y cambiando la variable a Comercio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changez la variable du champ Montant en Montant et touchez Retour. Répétez pour Commerçant en sélectionnant le champ Commerçant, en choisissant Entrée du raccourci et en changeant la variable en Commerçant."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Altere a variável do campo Valor para Valor e toque em Retornar. Repita para o comerciante selecionando o campo comerciante, escolhendo entrada de atalho e alterando a variável para comerciante."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将金额字段变量更改为金额并点击返回。通过选择 Merchant 字段、选择快捷方式输入并将变量更改为 Merchant，对 Merchant 重复此操作。"
          }
        }
      }
    },
