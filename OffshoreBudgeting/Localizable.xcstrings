    "Splitting transactions now supports splitting by percentage using a slider. This makes it so that the split amount value can be calculated easily." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يدعم تقسيم المعاملات الآن التقسيم حسب النسبة المئوية باستخدام شريط التمرير. وهذا يجعل من الممكن حساب قيمة المبلغ المقسم بسهولة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Aufteilung von Transaktionen unterstützt jetzt die prozentuale Aufteilung mithilfe eines Schiebereglers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Splitting transactions now supports splitting by percentage using a slider. This makes it so that the split amount value can be calculated easily."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La división de transacciones ahora permite dividir por porcentaje usando un deslizador. Esto facilita calcular el valor del monto dividido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le fractionnement des transactions permet maintenant de répartir par pourcentage à l’aide d’un curseur. Cela facilite le calcul du montant réparti."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A divisão de transações agora oferece suporte à divisão por porcentagem usando um controle deslizante. Isso faz com que o valor da divisão possa ser calculado facilmente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拆分交易现在支持使用滑块按百分比拆分。这使得可以容易地计算分割金额值。"
          }
        }
      }
    },
