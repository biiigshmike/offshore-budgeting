    "Helps Excursion Mode continue monitoring reliably when Offshore is not in the foreground." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يساعد وضع Excursion على مواصلة المراقبة بشكل موثوق عندما لا يكون Offshore في المقدمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilft dem Exkursionsmodus, die Überwachung zuverlässig fortzusetzen, wenn Offshore nicht im Vordergrund steht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Helps Excursion Mode continue monitoring reliably when Offshore is not in the foreground."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ayuda a que el modo Excursion siga supervisando de forma confiable cuando Offshore no esta en primer plano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
