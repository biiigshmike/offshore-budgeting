    "Budget Details" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تفاصيل الميزانية"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Budgetdetails"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Budget Details"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detalles del presupuesto"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Détails du budget"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
