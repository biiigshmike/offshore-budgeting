    "Duration" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مدة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dauer"
          }
        },
