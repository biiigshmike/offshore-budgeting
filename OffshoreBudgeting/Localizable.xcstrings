    "assistant.persona.transitionDescription" : {
      "comment" : "Introductory Marina description shown in the empty assistant state.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سأساعدك على البقاء متشجعًا ومستقرًا من خلال قراءات سريعة وعملية حول إنفاقك واتجاهاتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich helfe dir, motiviert und geerdet zu bleiben, mit schnellen, praktischen Einblicken in deine Ausgaben und Trends."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I’ll help you stay encouraged and grounded with quick, practical reads on your spending and trends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te ayudare a mantenerte con animos y con los pies en la tierra con lecturas rapidas y practicas sobre tus gastos y tendencias."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je t’aiderai a rester motive et ancre avec des lectures rapides et pratiques de tes depenses et tendances."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajudarei você a se manter encorajado e fundamentado com leituras rápidas e práticas sobre seus gastos e tendências."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我将通过快速、实用地解读您的支出和趋势来帮助您保持鼓励和脚踏实地。"
          }
        }
      }
    },
    "assistant.persona.unresolvedSubtitle" : {
      "comment" : "Unresolved prompt subtitle for Marina persona.",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حاول أن تسأل عن إجمالي الإنفاق، أو أهم الفئات، أو التغيير من شهر لآخر، أو أكبر النفقات."
