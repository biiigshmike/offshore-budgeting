    "You can delete the budget now, or tap Done to keep it." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك حذف الميزانية الآن، أو الضغط على \"تم\" للاحتفاظ بها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können das Budget jetzt löschen oder auf „Fertig“ tippen, um es beizubehalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes eliminar el presupuesto ahora o tocar Listo para conservarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can delete the budget now, or tap Terminé to keep it."
          }
        }
      }
    },
    "You can finish now, or create a starter budget so Home has planning context right away." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك الانتهاء الآن، أو إنشاء ميزانية أولية حتى يكون لدى المنزل سياق تخطيط على الفور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können jetzt fertig werden oder ein Startbudget erstellen, damit Home sofort über den Planungskontext verfügt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
