    "Choose one card for this automation, select one category for best results, set Run Immediately, and turn off Notify When Run." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر بطاقة واحدة لهذه الأتمتة، وحدد فئة واحدة للحصول على أفضل النتائج، وقم بتعيين التشغيل فورًا، وقم بإيقاف تشغيل الإشعار عند التشغيل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie eine Karte für diese Automatisierung aus, wählen Sie eine Kategorie für die besten Ergebnisse aus, legen Sie „Sofort ausführen“ fest und deaktivieren Sie „Bei Ausführung benachrichtigen“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose one card for this automation, select one category for best results, set Run Immediately, and turn off Notify When Run."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige una tarjeta para esta automatización, selecciona una categoría para obtener los mejores resultados, establece Ejecutar inmediatamente y desactiva Notificar al ejecutar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez une carte pour cette automatisation, sélectionnez une catégorie pour de meilleurs résultats, réglez Exécuter immédiatement et désactivez Notifier lors de l’exécution."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha um cartão para esta automação, selecione uma categoria para obter melhores resultados, defina Executar imediatamente e desative Notificar quando executar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为此自动化选择一张卡，选择一个类别以获得最佳结果，设置“立即运行”，然后关闭“运行时通知”。"
          }
        }
      }
    },
