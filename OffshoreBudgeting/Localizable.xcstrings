    "Add these screenshots to provide a visual walkthrough for new users." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف لقطات الشاشة هذه لتوفير إرشادات مرئية للمستخدمين الجدد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügen Sie diese Screenshots hinzu, um neuen Benutzern eine visuelle Anleitung zu bieten."
          }
        },
        "en" : {
          "stringUnit" : {
