        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إظهار المصاريف المخططة التالية لجميع البطاقات أو البطاقة المحددة."
          }
        }
      }
    },
    "Show upcoming planned expenses for all cards or a selected card.": {
      "localizations": {
