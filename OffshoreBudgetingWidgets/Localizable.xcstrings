    "Show a card and its expenses for a selected period.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra una cuenta y sus gastos para un período seleccionado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Afficher a card and its expenses for a selected period."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigen Sie eine Karte und ihre Ausgaben für einen ausgewählten Zeitraum an."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إبراز البطاقة ومصروفاتها لفترة محددة."
          }
        }
      }
    },
    "Show a card preview with spending for a selected period.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra una vista previa de una cuenta con gasto para un período seleccionado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche un aperçu d’une carte avec les dépenses pour une période choisie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigen Sie eine Kartenvorschau mit Ausgaben für einen ausgewählten Zeitraum an."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إظهار معاينة البطاقة مع الإنفاق لفترة محددة."
          }
        }
      }
    },
    "Show spend trends for all cards or a selected card.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra tendencias de gasto para todas las cuentas o una cuenta seleccionada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Afficher spend trends for all cards or a selected card."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgabentrends für alle Karten oder eine ausgewählte Karte anzeigen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إظهار اتجاهات الإنفاق لجميع البطاقات أو البطاقة المحددة."
          }
        }
      }
    },
    "Show the next planned expense for all cards or a selected card.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra el siguiente gasto planificado para todas las cuentas o una cuenta seleccionada."
